# ============================================
# Raio de Luz — Variáveis de Ambiente (exemplo)
# Copie para .env e preencha com seus valores
# ============================================

# Banco de dados PostgreSQL
DATABASE_URL="postgresql://usuario:senha@localhost:5432/raio_de_luz"

# JWT — use uma string longa e aleatória
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
JWT_EXPIRES_IN="7d"

# Email SMTP (Gmail / Brevo / Resend)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="seu-email@gmail.com"
SMTP_PASS="sua-senha-de-app"
EMAIL_FROM='"Raio de Luz" <contato@raiodeluz.com>'

# WhatsApp (Evolution API — https://github.com/EvolutionAPI/evolution-api)
WHATSAPP_API_URL="http://localhost:8080"
WHATSAPP_API_KEY="sua-api-key"
WHATSAPP_INSTANCE="raio-de-luz"
STORE_WHATSAPP="5588999999999"

# Cloudinary (opcional — para upload de imagens)
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_API_KEY="sua-api-key"
CLOUDINARY_API_SECRET="seu-api-secret"

# Frontend URL (para links em e-mails e CORS)
FRONTEND_URL="http://localhost:5173"

# Ambiente
NODE_ENV="development"
PORT=3333
