# ==============================================
#  RAIO DE LUZ — Variáveis de Ambiente (BACKEND)
# ==============================================
# Copie este arquivo para ".env" e preencha com os valores reais.
# O arquivo .env NÃO vai para o Git (contém segredos).

# ----- Servidor -----
NODE_ENV="development"
PORT="3333"
# URL pública do backend. Em dev local fica localhost.
# Para o webhook do Mercado Pago funcionar, use a URL do ngrok aqui.
API_URL="http://localhost:3333"
# URL do frontend (usada em CORS e nos redirects de pagamento)
FRONTEND_URL="http://localhost:5173"

# ----- Banco de dados (PostgreSQL) -----
DATABASE_URL="postgresql://USUARIO:SENHA@localhost:5432/raio_de_luz?schema=public"

# ----- Autenticacao (JWT) -----
# Use uma string longa e aleatoria, secreta. Troque por algo unico.
JWT_SECRET="troque-por-uma-chave-secreta-bem-longa-e-aleatoria"
JWT_EXPIRES_IN="7d"

# ----- Admin inicial (criado pelo seed) -----
# O seed cria a conta de administradora com estas credenciais.
# Em producao, defina uma senha FORTE aqui (e um email real).
ADMIN_EMAIL="admin@.com"
ADMIN_PASSWORD="troque-por-uma-senha-forte"
ADMIN_NAME="Administradora"

# ----- E-mail (notificacoes via Gmail) -----
# Use uma SENHA DE APP do Gmail (nao a senha normal). Exige verificacao em 2 etapas.
# Gere em: https://myaccount.google.com/apppasswords
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="deylianeempreendedora@gmail.com"
SMTP_PASS="cole-aqui-a-senha-de-app-de-16-digitos"
EMAIL_FROM='Raio de Luz <@gmail.com>'

# ----- WhatsApp da loja -----
# Numero no formato internacional (55 + DDD + numero), so digitos.
STORE_WHATSAPP="5583998154641"
# Evolution API (WhatsApp automatico) -- opcional, deixe vazio se nao usar.
WHATSAPP_API_URL=""
WHATSAPP_API_KEY=""
WHATSAPP_INSTANCE=""

# ----- Cloudinary (upload de imagens) -----
# Opcional. Sem isto, as imagens sao salvas localmente na pasta uploads/.
# Crie conta em https://cloudinary.com e pegue no Dashboard.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ----- Mercado Pago (pagamento -- Checkout Pro) -----
# Crie conta em https://www.mercadopago.com.br/developers
# Use as credenciais de TESTE (comecam com TEST-) para desenvolvimento.
MP_ACCESS_TOKEN="TEST-xxxxxxxx"
MP_PUBLIC_KEY="TEST-xxxxxxxx"

# ----- Melhor Envio (calculo de frete) -----
# Crie conta em https://melhorenvio.com.br (use sandbox para testes).
# Token gerado em: https://sandbox.melhorenvio.com.br/painel/gerenciar/tokens
MELHOR_ENVIO_TOKEN=""
# "true" usa o ambiente de testes (sandbox); "false" usa producao.
MELHOR_ENVIO_SANDBOX="true"
# CEP de onde a loja ENVIA os produtos (origem do frete). So digitos.
STORE_CEP_ORIGEM="63010000"

# ----- Frete gratis (FALLBACK apenas) -----
# Estes valores so sao usados se a configuracao no painel admin falhar.
# O controle real do frete gratis agora fica no Painel Admin > Frete.
FRETE_GRATIS_MIN_COMPRA="250"
FRETE_GRATIS_TETO="30"
