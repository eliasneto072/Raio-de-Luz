# ===== Backend (desenvolvimento) — Raio de Luz =====
# Com hot-reload via tsx watch

FROM node:20-slim

RUN apt-get update -y && apt-get install -y openssl

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .
RUN npx prisma generate

EXPOSE 3333

# Aplica migrations e roda com hot-reload
CMD npx prisma migrate deploy && npm run dev
