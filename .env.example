# ===== Variaveis do Docker (producao) =====
# Copie para .env na raiz e preencha. Usado pelo docker-compose.yml

# Banco de dados PostgreSQL (dentro do Docker)
POSTGRES_USER=raio
POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_DB=raio_de_luz

